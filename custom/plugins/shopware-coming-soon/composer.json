{
    "name": "micha/micha-coming-soon",
    "description": "Coming Soon & Maintenance Mode for Shopware 6 - per sales channel, with countdown, IP whitelist and preview link",
    "version": "1.1.1",
    "type": "shopware-platform-plugin",
    "license": "proprietary",
    "authors": [
        {
            "name": "Michael Barabanov",
            "homepage": "https://github.com/MichaelBarabanov",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.2",
        "shopware/core": "~6.6.0 || ~6.7.0",
        "shopware/storefront": "~6.6.0 || ~6.7.0"
    },
    "extra": {
        "shopware-plugin-class": "Micha\\ComingSoon\\MichaComingSoon",
        "plugin-icon": "src/Resources/config/plugin.png",
        "label": {
            "de-DE": "Coming Soon & Wartungsmodus",
            "en-GB": "Coming Soon & Maintenance Mode"
