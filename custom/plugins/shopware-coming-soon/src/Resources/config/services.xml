<?xml version="1.0" encoding="UTF-8"?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="Micha\ComingSoon\Service\ComingSoonService">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="media.repository"/>
        </service>

        <service id="Micha\ComingSoon\Service\BypassChecker"/>

        <service id="Micha\ComingSoon\Service\PathMatcher"/>

        <service id="Micha\ComingSoon\Subscriber\ComingSoonSubscriber">
            <argument type="service" id="Micha\ComingSoon\Service\ComingSoonService"/>
            <argument type="service" id="Micha\ComingSoon\Service\BypassChecker"/>
            <argument type="service" id="Micha\ComingSoon\Service\PathMatcher"/>
            <argument type="service" id="twig"/>
            <argument type="service" id="monolog.logger"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Micha\ComingSoon\Subscriber\CacheInvalidationSubscriber">
            <argument type="service" id="Shopware\Core\Framework\Adapter\Cache\CacheClearer"/>
            <argument type="service" id="monolog.logger"/>
            <tag name="kernel.event_subscriber"/>
        </service>
    </services>
</container>
