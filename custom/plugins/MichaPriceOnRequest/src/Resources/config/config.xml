<?xml version="1.0" encoding="UTF-8"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/shopware/shopware/trunk/src/Core/System/SystemConfig/Schema/config.xsd">

    <card>
        <title>Allgemein</title>
        <title lang="en-GB">General</title>

        <input-field type="text">
            <name>recipientEmail</name>
            <label>Empfänger E-Mail</label>
            <label lang="en-GB">Recipient Email</label>
            <helpText>An diese Adresse werden Preisanfragen geschickt</helpText>
            <required>true</required>
        </input-field>

        <input-field type="text">
            <name>buttonLabel</name>
            <label>Button-Text</label>
            <label lang="en-GB">Button Label</label>
            <defaultValue>Preis anfragen</defaultValue>
        </input-field>

        <input-field type="single-select">
            <name>mode</name>
            <label>Modus</label>
            <label lang="en-GB">Mode</label>
            <helpText>Alle Produkte: gilt für den gesamten Shop. Nur markierte: nur Produkte mit aktiviertem Custom Field</helpText>
            <helpText lang="en-GB">All products: applies shop-wide. Selected only: products with activated custom field only</helpText>
            <options>
                <option>
                    <id>all</id>
                    <name>Alle Produkte</name>
                    <name lang="en-GB">All products</name>
                </option>
                <option>
                    <id>selected</id>
                    <name>Nur markierte Produkte</name>
                    <name lang="en-GB">Selected products only</name>
                </option>
            </options>
            <defaultValue>selected</defaultValue>
        </input-field>

    </card>

    <card>
        <title>Spam-Schutz</title>
        <title lang="en-GB">Spam Protection</title>

        <input-field type="bool">
            <name>spamProtectionEnabled</name>
            <label>Spam-Schutz aktivieren</label>
            <label lang="en-GB">Enable Spam Protection</label>
            <helpText>Begrenzt die Anzahl der Anfragen pro IP-Adresse</helpText>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="int">
            <name>spamMaxRequests</name>
            <label>Max. Anfragen pro Stunde</label>
            <label lang="en-GB">Max. requests per hour</label>
            <helpText>Wie viele Anfragen eine IP-Adresse pro Stunde senden darf</helpText>
            <defaultValue>3</defaultValue>
        </input-field>

    </card>

    <card>
        <title>Bestätigungsmail</title>
        <title lang="en-GB">Confirmation Email</title>

        <input-field type="bool">
            <name>confirmationEmailEnabled</name>
            <label>Bestätigungsmail an Kunden senden</label>
            <label lang="en-GB">Send confirmation email to customer</label>
            <defaultValue>false</defaultValue>
        </input-field>

        <input-field type="text">
            <name>confirmationEmailSubject</name>
            <label>Betreff der Bestätigungsmail</label>
            <label lang="en-GB">Confirmation email subject</label>
            <defaultValue>Ihre Preisanfrage ist eingegangen</defaultValue>
        </input-field>

        <input-field type="textarea">
            <name>confirmationEmailText</name>
            <label>Text der Bestätigungsmail</label>
            <label lang="en-GB">Confirmation email text</label>
            <defaultValue>Vielen Dank für Ihre Anfrage. Wir melden uns so schnell wie möglich bei Ihnen.</defaultValue>
        </input-field>

    </card>

</config>