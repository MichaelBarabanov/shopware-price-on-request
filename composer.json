{
    "name": "michael-barabanov/shopware-price-on-request",
    "description": "Hides product price and shows a configurable inquiry form for Shopware 6",
    "type": "shopware-platform-plugin",
    "version": "1.0.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Michael Barabanov",
            "role": "Developer"
        }
    ],
    "require": {
        "shopware/core": "~6.7.0"
    },
    "extra": {
        "shopware-plugin-class": "MichaPriceOnRequest\\MichaPriceOnRequest",
        "label": {
            "de-DE": "Preis auf Anfrage",
            "en-GB": "Price on Request"
        },
        "description": {
            "de-DE": "Blendet den Produktpreis aus und zeigt ein konfigurierbares Anfrageformular",
            "en-GB": "Hides the product price and shows a configurable inquiry form"
        },
        "manufacturerLink": {
            "de-DE": "https://github.com/MichaelBarabanov",
            "en-GB": "https://github.com/MichaelBarabanov"
        }
    },
    "autoload": {
        "psr-4": {
            "MichaPriceOnRequest\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MichaPriceOnRequest\\Tests\\": "tests/"
        }
    }
}